{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "promotion_capsule.schema.json",
  "type": "object",
  "required": [
    "kind",
    "integration_id",
    "base_main_commit",
    "contract_commit",
    "bounded_batch_id",
    "patch_hash",
    "validation_refs",
    "status"
  ],
  "properties": {
    "kind": {
      "const": "promotion_capsule.v1"
    },
    "integration_id": {
      "type": "string",
      "minLength": 1
    },
    "base_main_commit": {
      "type": "string",
      "minLength": 1
    },
    "contract_commit": {
      "type": "string",
      "minLength": 1
    },
    "bounded_batch_id": {
      "type": "string",
      "minLength": 1
    },
    "patch_hash": {
      "type": "string",
      "minLength": 1
    },
    "validation_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "PENDING",
        "DENIED",
        "PROMOTED"
      ]
    },
    "promoted_commit": {
      "type": "string"
    },
    "rejection_reason": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
