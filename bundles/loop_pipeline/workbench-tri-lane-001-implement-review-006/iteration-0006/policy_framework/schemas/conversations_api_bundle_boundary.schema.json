      "minLength": 1
    },
    "materializer_owner": {
      "type": "string",
      "minLength": 1
    },
    "packet_contract_owner": {
      "type": "string",
      "minLength": 1
    },
    "admissibility_owner": {
      "type": "string",
      "minLength": 1
    },
    "bundle_id_pattern": {
      "type": "string",
      "minLength": 1
