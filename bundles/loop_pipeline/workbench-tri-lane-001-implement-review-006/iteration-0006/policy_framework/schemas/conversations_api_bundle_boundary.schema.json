        "type": "string",
        "minLength": 1
      }
    },
    "include_roles": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_checks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "deny_rules": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
