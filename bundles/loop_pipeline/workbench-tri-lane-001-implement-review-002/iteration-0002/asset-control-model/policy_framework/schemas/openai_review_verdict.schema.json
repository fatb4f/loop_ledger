{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openai_review_verdict.schema.json",
  "type": "object",
  "required": [
    "kind",
    "verdict",
    "summary",
    "scores",
    "findings",
    "next_action",
    "promotion_ready"
  ],
  "properties": {
    "kind": {
      "const": "openai_review_verdict.v1"
    },
    "verdict": {
      "type": "string",
      "enum": [
        "pass",
        "revise",
        "block"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "scores": {
      "type": "object",
      "required": [
        "correctness",
        "scope_control",
        "testability",
        "risk"
      ],
      "properties": {
        "correctness": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "scope_control": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "testability": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "risk": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        }
      },
      "additionalProperties": false
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "severity",
          "issue",
          "evidence",
          "fix"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "issue": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          },
          "fix": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    },
    "promotion_ready": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
