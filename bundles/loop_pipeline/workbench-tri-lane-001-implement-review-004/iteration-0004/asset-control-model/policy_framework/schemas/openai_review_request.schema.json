{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openai_review_request.schema.json",
  "type": "object",
  "required": [
    "kind",
    "contract",
    "conversation_context",
    "request",
    "response",
    "evidence",
    "promotion_threshold"
  ],
  "properties": {
    "kind": {
      "const": "openai_review_request.v1"
    },
    "contract": {
      "type": "object",
      "required": [
        "contract_id",
        "stage",
        "authority_refs"
      ],
      "properties": {
        "contract_id": {
          "type": "string",
          "minLength": 1
        },
        "stage": {
          "type": "string",
          "enum": [
            "PLAN",
            "IMPLEMENT",
            "VERIFY",
            "REVIEW"
          ]
        },
        "authority_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "conversation_context": {
      "$ref": "openai_conversation_context.schema.json"
    },
    "request": {
      "$ref": "openai_response_request.schema.json"
    },
    "response": {
      "$ref": "openai_response_snapshot.schema.json"
    },
    "events": {
      "type": "object",
      "properties": {
        "streaming_events": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "webhook_events": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "object",
      "required": [
        "checks",
        "artifacts"
      ],
      "properties": {
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "promotion_threshold": {
      "type": "object",
      "required": [
        "allow_promotion",
        "deny_if_missing_evidence"
      ],
      "properties": {
        "allow_promotion": {
          "type": "boolean"
        },
        "deny_if_missing_evidence": {
          "type": "boolean"
        },
        "required_score_floor": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
