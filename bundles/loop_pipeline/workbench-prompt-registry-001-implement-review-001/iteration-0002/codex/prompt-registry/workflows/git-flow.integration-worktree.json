{
  "id": "workflow.git_flow.integration_worktree",
  "kind": "workflow",
  "description": "Retrieval overlay for the canonical bounded-batch git-flow DAG.",
  "authority": {
    "source_of_truth_root": "control/git-flow/",
    "source_of_truth_refs": [
      "control/git-flow/git_flow.manifest.json",
      "control/git-flow/git_flow.dag.json",
      "control/git-flow/loop/README.md",
      "control/git-flow/plan/README.md",
      "control/git-flow/implement/README.md"
    ],
    "overlay_role": "retrieval_overlay"
  },
  "steps": [
    "contract_branch_open",
    "authority_gate",
    "contract_package_gate",
    "merge_contract_to_main",
    "spawn_bounded_batch_integration_worktree",
    "apply_batch_patch",
    "artifact_conformance_gate",
    "promotion_decision",
    "promote_patch_to_main"
  ]
}
