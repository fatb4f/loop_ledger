{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Git flow DAG",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "start",
    "nodes"
  ],
  "properties": {
    "kind": {
      "const": "git_flow_dag.v1"
    },
    "start": {
      "type": "string",
      "minLength": 1
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "next"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "next": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
