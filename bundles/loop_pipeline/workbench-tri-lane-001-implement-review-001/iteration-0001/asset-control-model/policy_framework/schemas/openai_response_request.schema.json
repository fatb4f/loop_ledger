{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openai_response_request.schema.json",
  "type": "object",
  "required": [
    "kind",
    "request_id",
    "model",
    "input",
    "conversation_context"
  ],
  "properties": {
    "kind": {
      "const": "openai_response_request.v1"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "input": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "array",
          "minItems": 1
        }
      ]
    },
    "instructions": {
      "type": "string",
      "minLength": 1
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "background": {
      "type": "boolean"
    },
    "stream": {
      "type": "boolean"
    },
    "store": {
      "type": "boolean"
    },
    "conversation_context": {
      "$ref": "openai_conversation_context.schema.json"
    }
  },
  "additionalProperties": false
}
